# Google Analytics 4（本番のみ設定。開発では未設定のままにするとGAが読み込まれません）
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# basePath（next.config.ts と一致させる）
NEXT_PUBLIC_BASE_PATH=/apps/yokosawa-rangetable-training

# vercel.app 直アクセスを canonical へ寄せる
ENABLE_VERCEL_CANONICAL_REDIRECT=true
VERCEL_CANONICAL_REDIRECT_URL=https://yutar0xff.com/apps/yokosawa-rangetable-training
